# ── Database (Supabase Postgres, ap-south-1 Mumbai) ──────────────
# Pooled connection string (transaction mode) — all queries go through
# postgres-js against this URL, never the Supabase JS client.
DATABASE_URL=postgres://postgres.<project-ref>:<password>@aws-1-ap-south-1.pooler.supabase.com:6543/postgres

# ── Supabase (AUTH ONLY) ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Storage (S3 protocol — Supabase Storage S3 endpoint) ─────────
# Buckets: certificates, cpd-evidence (private)
# Keys are optional: when S3_ACCESS_KEY_ID is empty, lib/storage.ts falls
# back to Supabase S3 session-token auth (project ref + anon key +
# service-role JWT). Mint real keys in Dashboard → Settings → Storage
# to switch to key-pair auth (required on MinIO/R2/S3 fallback stacks).
S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
S3_REGION=ap-south-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── Email (Resend) ────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM="Gradus CPD <noreply@cpd.mma.org.mv>"

# ── App ───────────────────────────────────────────────────────────
# Base URL for certificate QR verify links: <APP_URL>/verify/<uuid>
NEXT_PUBLIC_APP_URL=http://localhost:3000
